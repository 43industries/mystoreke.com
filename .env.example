# Copy to .env.local for local dev. In Vercel: Project → Settings → Environment Variables.

# Server-only (API routes, server components) — never expose the service role key to the client
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Client — safe to expose (anon key is public in the browser)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# M-Pesa (Safaricom Daraja STK). Server-only except the toggle below.
# Callback URL must be HTTPS and reachable on the public internet (use ngrok in dev).
MPESA_ENV=sandbox
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=
MPESA_PASSKEY=
MPESA_CALLBACK_URL=https://YOUR_DOMAIN/api/payments/mpesa/callback
# CustomerPayBillOnline (default) or CustomerBuyGoodsOnline for till
# MPESA_TRANSACTION_TYPE=CustomerPayBillOnline

# Set to "true" to show the STK flow on listing pages (requires Daraja + mpesa_payments table).
NEXT_PUBLIC_MPESA_ENABLED=false

# Comma-separated Supabase user UUIDs allowed to call GET /api/admin/overview and use /admin
MYSTORE_ADMIN_USER_IDS=
