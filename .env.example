# Copy to .env.local for local dev. In Vercel: Project → Settings → Environment Variables.

# Canonical public URL (Open Graph / Twitter metadata). Set in Vercel Production to https://mystoreke.com
# Preview deploys use VERCEL_URL automatically if this is unset.
# NEXT_PUBLIC_SITE_URL=https://mystoreke.com

# Server URL (same host as NEXT_PUBLIC_ in hosted Supabase)
SUPABASE_URL=

# Client — safe to expose in the browser
NEXT_PUBLIC_SUPABASE_URL=
# Legacy JWT anon key, OR new publishable key (sb_publishable_...):
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Server-only — legacy JWT service_role OR new secret key (sb_secret_...). Never NEXT_PUBLIC_*
SUPABASE_SERVICE_ROLE_KEY=
# SUPABASE_SECRET_KEY=

# M-Pesa (Safaricom Daraja STK). Server-only except the toggle below.
# Callback URL must be HTTPS and reachable on the public internet (use ngrok in dev).
MPESA_ENV=sandbox
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=
MPESA_PASSKEY=
MPESA_CALLBACK_URL=https://YOUR_DOMAIN/api/payments/mpesa/callback
# CustomerPayBillOnline (default) or CustomerBuyGoodsOnline for till
# MPESA_TRANSACTION_TYPE=CustomerPayBillOnline

# Set to "true" to show the STK flow on listing pages (requires Daraja + mpesa_payments table).
NEXT_PUBLIC_MPESA_ENABLED=false

# Comma-separated Supabase user UUIDs allowed to call GET /api/admin/overview and use /admin
MYSTORE_ADMIN_USER_IDS=

# --- Optional: automation (npm run mvp-setup / npm run mvp-smoke) ---
# Direct Postgres URL (Session mode) so mvp-setup can run supabase/mvp_marketplace.sql via psql.
# DATABASE_URL=postgresql://postgres.[ref]:[YOUR-PASSWORD]@aws-0-[region].pooler.supabase.com:5432/postgres

# Dev-only test user for mvp-smoke (create this user in Supabase Auth first).
# MVP_TEST_EMAIL=
# MVP_TEST_PASSWORD=

# Base URL for mvp-smoke (default http://127.0.0.1:3000).
# MVP_SMOKE_BASE_URL=
